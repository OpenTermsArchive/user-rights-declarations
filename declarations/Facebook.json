    "Terms of Service": {
      "combine": [
        {
          "fetch": "https://mbasic.facebook.com/legal/terms/plain_text_terms/",
          "select": [
            "[role=\"main\"]"
          ],
          "remove": [
            "img",
            "[href=\"#\"]"
          ]
        },
        {
          "fetch": "https://www.facebook.com/legal/eu-ai-terms",
          "select": [
            {
              "startBefore": "[role=\"main\"]",
              "endBefore": "[role=\"separator\"]"
            }
          ]
        }
      ],
      "filter": [
        {
          "removeQueryParams": [
            "h",
            "_nc_gid",
            "oh"
          ]
        }
      ],
      "executeClientScripts": true
    },
