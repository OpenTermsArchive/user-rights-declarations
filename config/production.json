{
  "@opentermsarchive/engine": {
    "recorder": {
      "versions": {
        "storage": {
          "git": {
            "snapshotIdentiferTemplate": "https://github.com/OpenTermsArchive/user-rights-snapshots/commit/%SNAPSHOT_ID",
            "repository": "git@github.com:OpenTermsArchive/user-rights-versions.git",
            "path": "./data/versions"
          }
        }
      },
      "snapshots": {
        "storage": {
          "git": {
            "repository": "git@github.com:OpenTermsArchive/user-rights-snapshots.git",
            "path": "./data/snapshots"
          }
        }
      }
    },
    "fetcher": {
      "language": "en-IE, en-GB, en"
    },
    "reporter": {
      "type": "github",
      "repositories": {
        "declarations": "OpenTermsArchive/user-rights-declarations",
        "versions": "OpenTermsArchive/user-rights-versions",
        "snapshots": "OpenTermsArchive/user-rights-snapshots"
      }
    },
    "dataset": {
      "title": "user-rights",
      "versionsRepositoryURL": "https://github.com/OpenTermsArchive/user-rights-versions"
    },
    "collection-api": {
      "port": 3000,
      "basePath": "/collection-api",
      "feed": {
        "versionUrlTemplate": "https://github.com/OpenTermsArchive/demo-versions/commit/%VERSION_ID"
      }
    },
    "logger": {
      "timestampPrefix": false,
      "smtp": {
        "host": "smtp-relay.brevo.com",
        "port": 587,
        "username": "admin@opentermsarchive.org"
      }
    }
  }
}
